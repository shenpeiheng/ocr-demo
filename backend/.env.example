# ==============================================================================
# OCR工业图片识别系统 - 环境变量配置文件示例
# ==============================================================================
# 
# 说明：
# 1. 将此文件复制为 .env 文件：cp .env.example .env
# 2. 根据实际需求修改配置值
# 3. 生产环境请务必修改所有默认值，特别是密钥类配置
# 
# ==============================================================================
# 第一部分：Flask应用基础配置
# ==============================================================================

# Flask应用密钥，用于会话加密等安全功能
# 生产环境必须使用强随机字符串，长度建议32位以上
# 生成命令：python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-change-in-production

# 调试模式，开发环境建议开启，生产环境必须关闭
# 可选值：true/false
DEBUG=true

# 应用监听端口，默认5000
PORT=5000

# 最大文件上传大小（单位：字节），默认16MB
# 计算公式：16 * 1024 * 1024 = 16777216
MAX_CONTENT_LENGTH=16777216

# ==============================================================================
# 第二部分：OCR服务配置
# ==============================================================================

# OCR服务选择：true=使用模拟数据，false=使用真实OCR API
# 开发测试阶段建议使用模拟模式，生产环境使用真实API
OCR_USE_MOCK=true

# OCR置信度阈值，范围0.0-1.0
# 低于此值的识别结果将被过滤
OCR_CONFIDENCE_THRESHOLD=0.5

# ==============================================================================
# 第三部分：百度OCR API配置（需要真实API时配置）
# ==============================================================================
# 获取方式：访问 https://ai.baidu.com/tech/ocr 注册并创建应用
# 注意：以下三个配置项必须同时设置才生效

# 百度AI应用ID
BAIDU_APP_ID=your_app_id_here

# 百度AI API Key
BAIDU_API_KEY=your_api_key_here

# 百度AI Secret Key
BAIDU_SECRET_KEY=your_secret_key_here

# ==============================================================================
# 第四部分：图像处理配置
# ==============================================================================

# 是否启用图像预处理（调整大小、增强对比度等）
# 可选值：true/false
PREPROCESS_ENABLED=true

# 图像预处理最大宽度（像素）
IMAGE_RESIZE_WIDTH=1600

# 图像预处理最大高度（像素）
IMAGE_RESIZE_HEIGHT=1200

# ==============================================================================
# 第五部分：输出配置
# ==============================================================================

# 是否生成Excel输出文件
OUTPUT_EXCEL_ENABLED=true

# 是否生成JSON输出文件
OUTPUT_JSON_ENABLED=true

# 是否生成可视化标注图像
OUTPUT_VISUALIZATION_ENABLED=true

# ==============================================================================
# 第六部分：文件上传配置
# ==============================================================================

# 允许上传的图片格式（逗号分隔，不要修改格式）
# 当前支持：png,jpg,jpeg,bmp,tiff,gif
ALLOWED_EXTENSIONS=PNG,JPG,JPEG,BMP,TIFF,GIF

# ==============================================================================
# 第七部分：高级配置（可选）
# ==============================================================================

# 日志级别：DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# 是否启用CORS跨域，前端分离部署时需要开启
ENABLE_CORS=true

# 数据库连接字符串（如果未来需要数据库支持）
# DATABASE_URL=postgresql://user:password@localhost/ocr_db

# ==============================================================================
# 安全注意事项
# ==============================================================================
# 
# 生产环境部署必须：
# 1. 设置 DEBUG=false
# 2. 生成强随机 SECRET_KEY
# 3. 配置真实的百度OCR API密钥
# 4. 设置合适的文件上传大小限制
# 5. 使用HTTPS协议
# 6. 配置防火墙限制访问
# 
# 开发环境建议：
# 1. 使用 OCR_USE_MOCK=true 避免API调用
# 2. 开启 DEBUG=true 方便调试
# 3. 使用默认配置快速启动
# 
# ==============================================================================
# 快速启动命令
# ==============================================================================
# 
# 1. 安装依赖：pip install -r requirements.txt
# 2. 复制配置文件：cp .env.example .env
# 3. 启动服务：python run.py 或 flask run
# 4. 访问地址：http://localhost:5000
# 
# ==============================================================================