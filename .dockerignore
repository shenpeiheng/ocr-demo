# Docker忽略文件
# 忽略不必要的文件和目录，减少镜像大小

# Git
.git/
.gitignore
.gitattributes

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
venv/
env/
ENV/
env.bak/
venv.bak/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Test
coverage/
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# Documentation
docs/_build/

# Frontend build artifacts
frontend/node_modules/
frontend/.cache/
frontend/.parcel-cache/
frontend/dist/

# Uploads (在容器中重新创建)
frontend/uploads/*

# 临时文件
temp/
tmp/

# 配置文件（可选，如果需要挂载）
.env
*.env.local
*.env.*.local